{
  "name": "sessionizer",
  "version": "1.1.1",
  "description": "Windows parental screen-time limiter",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.14.1 <25"
  },
  "scripts": {
    "dev": "tauri dev",
    "vite": "vite",
    "build": "vite build",
    "build:tauri": "tauri build",
    "preview": "vite preview",
    "format": "biome format .",
    "format:write": "biome format --write .",
    "lint": "biome lint src vite.config.ts && node ./scripts/check-architecture.mjs",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-autostart": "^2.2.0",
    "@tauri-apps/plugin-notification": "^2.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.2.4",
    "vitest": "^4.1.2"
  }
}
