{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sessionizer",
  "identifier": "com.sessionizer.desktop",
  "version": "1.0.0",
  "build": {
    "beforeBuildCommand": "pnpm run build",
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Sessionizer",
        "label": "main",
        "width": 800,
        "height": 600,
        "resizable": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "autostart": {
      "macOSExtraArgs": [],
      "args": ["--minimized"]
    },
    "notification": {
      "all": true
    },
    "shell": {
      "all": true,
      "open": true
    }
  }
}
